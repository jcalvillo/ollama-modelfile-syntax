{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "\"\"\"", "close": "\"\"\"" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "{{", "close": "}}" }
  ],
  "surroundingPairs": [
    ["\"\"\"", "\"\"\""],
    ["\"", "\""],
    ["'", "'"],
    ["{{", "}}"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*\"\"\"",
      "end": "^\\s*\"\"\""
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
